# Database (SQLite for local dev without Docker)
DATABASE_URL=sqlite:///./vuln_mgmt.db
# DATABASE_URL=postgresql://vuln:vuln@localhost:5432/vuln_mgmt

DEBUG=true
SECRET_KEY=change-me-to-random-32-chars-minimum

# NVD API key (optional, higher rate limits)
# NVD_API_KEY=your-nvd-api-key
NVD_SYNC_DAYS=7
NVD_MAX_RESULTS=100

ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Telegram notifications (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
